{
  "name": "dokploy-to-pangolin",
  "module": "index.ts",
  "type": "module",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "preinstall": "bunx only-allow bun",
    "dev": "bun run --watch ./src/index.ts",
    "build": "bun run build.ts",
    "start": "bun ./build/index.js",
    "gen:api": "openapi-typescript ./assets/pangolin-openapi.yml --output src/lib/pangolin.d.ts",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepare": "husky",
    "check": "tsc --noEmit",
    "release": "changelogen release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "^1.3.11",
    "changelogen": "^0.6.2",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "openapi-fetch": "^0.17.0"
  },
  "packageManager": "bun@1.3.10"
}
